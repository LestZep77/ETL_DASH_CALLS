# ══════════════════════════════════════════════════════════════
# MySQL/MariaDB - Base de datos ORIGEN
# ══════════════════════════════════════════════════════════════
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=tu_usuario_mysql
MYSQL_PASSWORD=tu_password_mysql
MYSQL_DATABASE=nombre_bd_mysql

# ══════════════════════════════════════════════════════════════
# SQL Server - Base de datos DESTINO
# ══════════════════════════════════════════════════════════════
SQLSERVER_HOST=SERVIDOR\INSTANCIA
SQLSERVER_PORT=1433
SQLSERVER_USER=tu_usuario_sqlserver
SQLSERVER_PASSWORD=tu_password_sqlserver
SQLSERVER_DATABASE=NombreBaseDatos
SQLSERVER_DRIVER={ODBC Driver 18 for SQL Server}
SQLSERVER_SCHEMA=dbo
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes

# ══════════════════════════════════════════════════════════════
# MySQL/MariaDB - SSL (opcional, solo si el servidor lo requiere)
# ══════════════════════════════════════════════════════════════
MYSQL_SSL_ENABLED=no
# MYSQL_SSL_CA=ruta/al/ca-cert.pem
# MYSQL_SSL_CERT=ruta/al/client-cert.pem
# MYSQL_SSL_KEY=ruta/al/client-key.pem

# ══════════════════════════════════════════════════════════════
# Configuración ETL
# ══════════════════════════════════════════════════════════════
TABLE_NAME_DESTINO=tbl_dash_calls_etl
BATCH_SIZE=1000

LOG_DIR=logs
LOG_LEVEL=INFO
